{
  "expo": {
    "name": "HeadCount",
    "slug": "headcount",
    "owner": "ctrlaltorion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "headcount",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#090909",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#090909"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.orion.headcount",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.orion.headcount",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090909"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "com.android.vending.BILLING"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-image-picker", {
        "photosPermission": "HeadCount needs access to your photos so you can add a picture to a contact.",
        "cameraPermission": "HeadCount needs camera access so you can take a photo for a contact."
      }],
      ["react-native-google-mobile-ads", {
        "androidAppId": "ca-app-pub-1946277948152462~5775175668"
      }]
    ],
    "experiments": { "typedRoutes": false },
    "runtimeVersion": { "policy": "appVersion" },
    "updates": { "url": "https://u.expo.dev/3beb9bdf-2656-443c-87b9-86b4e9624efb" },
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "3beb9bdf-2656-443c-87b9-86b4e9624efb" }
    }
  }
}
